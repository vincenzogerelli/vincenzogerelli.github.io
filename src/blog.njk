---
layout: base.njk
mainId: blog
title: Blog
permalink: /blog/
---
<h2 class="page-header"><a href="/blog/">Blog</a></h2>

<ul class="post-list">
{%- for post in collections.post | reverse %}
  <li class="post">
    <div class="post-date">
      <time datetime="{{ post.date | dataIso }}">{{ post.date | dataLeggibile }}</time>
    </div>
    <h3 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <p class="blog-post-preview-text">
      {{ post.content | striptags | truncate(250) }}
      <a href="{{ post.url }}">Read More&nbsp;→</a>
    </p>
  </li>
{%- endfor %}
</ul>
